<mujoco model="earth_normal">
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.1 0.2 0.3" rgb2="0.2 0.3 0.4"
             width="300" height="300"/>
    <material name="grid" texture="grid" texrepeat="6 6" texuniform="true" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1"/>
    <geom name="floor" type="plane" size="0 0 0.05" material="grid"
          friction="1 0.005 0.0001"/>

    <body name="ball" pos="0 0 1.5">
      <freejoint/>
      <geom name="ball" type="sphere" size="0.1" rgba="0.9 0.3 0.3 1"
            mass="0.5" friction="0.5 0.005 0.0001"
            solref="0.01 1" solimp="0.9 0.95 0.001"/>
    </body>
  </worldbody>
</mujoco>
