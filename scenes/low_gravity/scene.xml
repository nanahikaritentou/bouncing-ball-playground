<mujoco model="low_gravity">
  <option timestep="0.002" gravity="0 0 -1.62" integrator="RK4"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.05 0.05 0.1" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.18 0.16" rgb2="0.3 0.27 0.24"
             width="300" height="300"/>
    <material name="grid" texture="grid" texrepeat="6 6" texuniform="true" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1"/>
    <geom name="floor" type="plane" size="0 0 0.05" material="grid"
          friction="1 0.005 0.0001"/>

    <body name="ball" pos="0 0 2.5">
      <freejoint/>
      <geom name="ball" type="sphere" size="0.12" rgba="0.85 0.85 0.95 1"
            mass="0.4" friction="0.5 0.005 0.0001"
            solref="0.012 1" solimp="0.92 0.96 0.001"/>
    </body>
  </worldbody>
</mujoco>
