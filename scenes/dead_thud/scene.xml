<mujoco model="dead_thud">
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight diffuse="0.55 0.55 0.55" ambient="0.25 0.25 0.25" specular="0 0 0"/>
    <rgba haze="0.18 0.18 0.2 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.18 0.18 0.22" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.16 0.16 0.18" rgb2="0.22 0.22 0.25"
             width="300" height="300"/>
    <material name="grid" texture="grid" texrepeat="6 6" texuniform="true" reflectance="0.05"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1"/>
    <geom name="floor" type="plane" size="0 0 0.05" material="grid"
          friction="1.5 0.01 0.001"/>

    <body name="ball" pos="0 0 1.5">
      <freejoint/>
      <geom name="ball" type="sphere" size="0.1" rgba="0.5 0.45 0.4 1"
            mass="2.0" friction="1.2 0.01 0.001"
            solref="0.05 1.5" solimp="0.5 0.6 0.01"/>
    </body>
  </worldbody>
</mujoco>
